  "keyFeatures": [
    "Match creation and lifecycle management for CS2 with MatchZy and PugSharp support",
    "Steam OAuth and local username/password authentication",
    "Team management with player rosters and Steam ID tracking",
    "Season and tournament management with Challonge bracket integration",
    "Automatic statistics tracking: map stats, player stats, vetoes, and leaderboards",
    "Game server management with RCON support",
    "Demo and backup file upload and retrieval",
    "Redis session store support",
    "Docker and Docker Compose deployment support",
    "OpenAPI/Swagger documentation at /api-docs"
  ],
  "publicApiSurface": [
    "GET/POST/PUT/DELETE /users",
    "GET/POST/PUT/DELETE /teams",
